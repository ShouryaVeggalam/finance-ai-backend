APP_NAME=Celestra Finance AI
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

DATABASE_URL=postgresql+asyncpg://celestra:celestra_secret@localhost:5432/celestra_finance
DATABASE_URL_SYNC=postgresql://celestra:celestra_secret@localhost:5432/celestra_finance
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=celestra
S3_SECRET_KEY=celestra_secret
S3_BUCKET=celestra-finance
S3_REGION=us-east-1

FRONTEND_URL=https://finance-ai--dun.vercel.app
